{
  "name": "tasarubat-riyadh",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "npm run seo && npm run favicons && npm run fonts:material",
    "dev": "next dev",
    "seo": "node scripts/generate-static-seo.mjs",
    "favicons": "python scripts/generate-favicons.py",
    "fonts:material": "node scripts/copy-material-symbols-font.mjs",
    "prebuild": "node scripts/verify-no-metadata-routes.mjs && node scripts/verify-public-images.mjs && npm run fonts:material && node scripts/generate-static-seo.mjs && npx tsx scripts/generate-jsonld-graphs.ts && npm run typecheck",
    "build": "next build",
    "postbuild": "node scripts/inline-jsonld-html.mjs && node scripts/verify-jsonld-html.mjs",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy out --project-name=manzilcare",
    "preview:static": "npx serve out",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "images": "powershell -ExecutionPolicy Bypass -File scripts/download-original-images.ps1",
    "images:optimize-page": "node scripts/optimize-page-images.mjs",
    "images:logo-hero": "node scripts/generate-logo-hero-cover.mjs",
    "areas:content": "node scripts/generate-area-markdown.mjs",
    "areas:data": "node scripts/build-neighborhoods-registry.mjs"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@fontsource/material-symbols-outlined": "^5.2.45",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
